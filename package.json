{
  "name": "runcard",
  "version": "0.1.0",
  "description": "Generate compact local run cards for repositories.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "runcard": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "check": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "pretest": "npm run build",
    "test": "tsc -p tsconfig.test.json && node --test .tmp/test-dist/tests/**/*.test.js",
    "smoke": "node dist/cli.js scan --fixture node-cli --out .tmp/smoke --json .tmp/smoke/run-card.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "runbook",
    "automation",
    "agents",
    "repository"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rogerchappel/runcard.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/runcard/issues"
  },
  "homepage": "https://github.com/rogerchappel/runcard#readme"
}
